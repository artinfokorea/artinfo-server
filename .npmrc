# pnpm을 npm/yarn처럼 완전히 평탄한 node_modules로 설치한다.
# 운영 실행은 빌드된 dist를 node로 직접 구동(node dist/main)하는데, pnpm 기본
# strict 레이아웃에서는 express 같은 전이(transitive) 의존성이 최상위 node_modules에
# 노출되지 않아 require('express')가 MODULE_NOT_FOUND로 실패한다.
# hoisted 링커는 npm과 동일한 평탄 구조를 만들어(로컬 npm 설치와 동일) 이를 방지한다.
node-linker=hoisted
shamefully-hoist=true
